ASPNETCORE_ENVIRONMENT=Production
LAWWATCHER_API_IMAGE=ghcr.io/przemekp95/lawwatcher-api:latest
LAWWATCHER_PORTAL_IMAGE=ghcr.io/przemekp95/lawwatcher-portal:latest
LAWWATCHER_WORKER_LITE_IMAGE=ghcr.io/przemekp95/lawwatcher-worker-lite:latest
LAWWATCHER_WORKER_AI_IMAGE=ghcr.io/przemekp95/lawwatcher-worker-ai:latest
LAWWATCHER_WORKER_DOCUMENTS_IMAGE=ghcr.io/przemekp95/lawwatcher-worker-documents:latest
LAWWATCHER_WORKER_NOTIFICATIONS_IMAGE=ghcr.io/przemekp95/lawwatcher-worker-notifications:latest
LAWWATCHER_WORKER_PROJECTION_IMAGE=ghcr.io/przemekp95/lawwatcher-worker-projection:latest
LAWWATCHER_WORKER_REPLAY_IMAGE=ghcr.io/przemekp95/lawwatcher-worker-replay:latest
SQLSERVER_SA_PASSWORD=ChangeMe!123456
SQLSERVER_HOST_PORT=1433
RABBITMQ_DEFAULT_USER=lawwatcher
RABBITMQ_DEFAULT_PASS=ChangeMe!123456
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
MINIO_ROOT_USER=lawwatcher
MINIO_ROOT_PASSWORD=ChangeMe!123456
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
API_HOST_PORT=8080
PORTAL_HOST_PORT=8081
SQLSERVER_DATABASE=LawWatcher
CONNECTIONSTRINGS__LAWWATCHERSQLSERVER=Server=sqlserver,1433;Database=LawWatcher;User Id=sa;Password=ChangeMe!123456;TrustServerCertificate=True;Encrypt=False
CONNECTIONSTRINGS__RABBITMQ=amqp://lawwatcher:ChangeMe!123456@rabbitmq:5672/
STORAGE__MINIO__ENDPOINT=http://minio:9000
STORAGE__MINIO__ACCESSKEY=lawwatcher
STORAGE__MINIO__SECRETKEY=ChangeMe!123456
LAWWATCHER__PORTALAPI__BASEURL=http://api:8080
LAWWATCHER__RUNTIME__CAPABILITIES__SQLFULLTEXT=false
LAWWATCHER__SEEDDATA__ENABLEDEFAULTOPERATORSEED=false
LAWWATCHER__SEEDDATA__ENABLEDEFAULTAPICLIENTSEED=false
SEARCH__OPENSEARCH__BASEURL=
SEARCH__OPENSEARCH__INDEXNAME=lawwatcher-search-documents
AI__MODE=on-demand
AI__OLLAMA__BASEURL=http://ollama:11434
AI__OLLAMA__HOST=0.0.0.0:11434
AI__OLLAMA__KEEPALIVE=0
AI__OLLAMA__EMBEDDINGMODEL=nomic-embed-text
WORKERS__LITE__MAXCONCURRENCY=2
WORKERS__AI__MAXCONCURRENCY=1
WORKERS__DOCUMENTS__MAXCONCURRENCY=1
WORKERS__NOTIFICATIONS__MAXCONCURRENCY=1
WORKERS__REPLAY__MAXCONCURRENCY=1
WORKERS__PROJECTION__MAXCONCURRENCY=1
ENABLE_OPENSEARCH=false
