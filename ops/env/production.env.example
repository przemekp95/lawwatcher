LAWWATCHER_PRODUCT_VERSION=v1.0.0
ASPNETCORE_ENVIRONMENT=Production
LAWWATCHER_API_IMAGE=ghcr.io/przemekp95/lawwatcher-api:v1.0.0
LAWWATCHER_PORTAL_IMAGE=ghcr.io/przemekp95/lawwatcher-portal:v1.0.0
LAWWATCHER_WORKER_AI_IMAGE=ghcr.io/przemekp95/lawwatcher-worker-ai:v1.0.0
LAWWATCHER_WORKER_DOCUMENTS_IMAGE=ghcr.io/przemekp95/lawwatcher-worker-documents:v1.0.0
LAWWATCHER_WORKER_NOTIFICATIONS_IMAGE=ghcr.io/przemekp95/lawwatcher-worker-notifications:v1.0.0
LAWWATCHER_WORKER_PROJECTION_IMAGE=ghcr.io/przemekp95/lawwatcher-worker-projection:v1.0.0
LAWWATCHER_WORKER_REPLAY_IMAGE=ghcr.io/przemekp95/lawwatcher-worker-replay:v1.0.0
SQLSERVER_SA_PASSWORD=__CHANGE_ME_SQLSERVER_SA_PASSWORD__
SQLSERVER_HOST_PORT=1433
RABBITMQ_DEFAULT_USER=lawwatcher
RABBITMQ_DEFAULT_PASS=__CHANGE_ME_RABBITMQ_PASSWORD__
MINIO_ROOT_USER=lawwatcher
MINIO_ROOT_PASSWORD=__CHANGE_ME_MINIO_ROOT_PASSWORD__
API_HOST_PORT=8080
PORTAL_HOST_PORT=8081
WORKER_AI_HEALTH_PORT=5392
WORKER_PROJECTION_HEALTH_PORT=5393
WORKER_NOTIFICATIONS_HEALTH_PORT=5394
WORKER_REPLAY_HEALTH_PORT=5395
WORKER_DOCUMENTS_HEALTH_PORT=5396
SQLSERVER_DATABASE=LawWatcher
CONNECTIONSTRINGS__LAWWATCHERSQLSERVER=Server=sqlserver,1433;Database=LawWatcher;User Id=sa;Password=__CHANGE_ME_SQLSERVER_SA_PASSWORD__;TrustServerCertificate=True;Encrypt=False
CONNECTIONSTRINGS__RABBITMQ=amqp://lawwatcher:__CHANGE_ME_RABBITMQ_PASSWORD__@rabbitmq:5672/
STORAGE__MINIO__ENDPOINT=http://minio:9000
STORAGE__MINIO__ACCESSKEY=lawwatcher
STORAGE__MINIO__SECRETKEY=__CHANGE_ME_MINIO_ROOT_PASSWORD__
LAWWATCHER__PORTALAPI__BASEURL=http://api:8080
LAWWATCHER__RUNTIME__CAPABILITIES__SQLFULLTEXT=false
LAWWATCHER__RUNTIME__CAPABILITIES__OCR=true
LAWWATCHER__BOOTSTRAP__SECRET=__CHANGE_ME_BOOTSTRAP_SECRET__
LAWWATCHER__BOOTSTRAP__ENABLEDEMODATA=false
LAWWATCHER__WEBHOOKS__BACKEND=SignedHttp
LAWWATCHER__WEBHOOKS__SIGNINGSECRET=__CHANGE_ME_WEBHOOK_SIGNING_SECRET__
SEARCH__OPENSEARCH__BASEURL=http://opensearch:9200
SEARCH__OPENSEARCH__INDEXNAME=lawwatcher-search-documents
AI__MODE=on-demand
AI__OLLAMA__BASEURL=http://ollama:11434
AI__OLLAMA__HOST=0.0.0.0:11434
AI__OLLAMA__KEEPALIVE=5m
AI__OLLAMA__EMBEDDINGMODEL=nomic-embed-text
WORKERS__LITE__MAXCONCURRENCY=4
WORKERS__AI__MAXCONCURRENCY=2
WORKERS__DOCUMENTS__MAXCONCURRENCY=2
WORKERS__NOTIFICATIONS__MAXCONCURRENCY=2
WORKERS__REPLAY__MAXCONCURRENCY=1
WORKERS__PROJECTION__MAXCONCURRENCY=2
ENABLE_OPENSEARCH=true
OPENSEARCH_HTTP_PORT=9200
OPENSEARCH_TRANSPORT_PORT=9300
OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g
