    private async Task HandleUpdateApiClientAsync()
    {
        await ExecuteBusyActionAsync(async () =>
        {
            await AdminClient.UpdateApiClientAsync(
                ParseRequiredGuid(_apiClientUpdate.ApiClientId, "API client"),
                new UpdateApiClientRequest(
                    _apiClientUpdate.Name,
                    string.IsNullOrWhiteSpace(_apiClientUpdate.Token) ? null : _apiClientUpdate.Token,
                    ParseCsv(_apiClientUpdate.ScopesCsv)),
                _loadCancellation.Token);

            _apiClientUpdate = new ApiClientUpdateInput();
            await LoadDataAsync();
            SetSuccess("API client updated.");
        });
    }

    private async Task LoadDataAsync()
    {
        var operatorsTask = AdminClient.GetOperatorsAsync(_loadCancellation.Token);
        var profilesTask = AdminClient.GetProfilesAsync(_loadCancellation.Token);
        var subscriptionsTask = AdminClient.GetSubscriptionsAsync(_loadCancellation.Token);
        var webhooksTask = AdminClient.GetWebhooksAsync(_loadCancellation.Token);
        var apiClientsTask = AdminClient.GetApiClientsAsync(_loadCancellation.Token);

        await Task.WhenAll(operatorsTask, profilesTask, subscriptionsTask, webhooksTask, apiClientsTask);

        _operators = (await operatorsTask).ToList();
        _profiles = (await profilesTask).ToList();
        _subscriptions = (await subscriptionsTask).ToList();
        _webhooks = (await webhooksTask).ToList();
        _apiClients = (await apiClientsTask).ToList();
        _bootstrapStatus = await AdminClient.GetBootstrapStatusAsync(_loadCancellation.Token);
    }

    private async Task ExecuteBusyActionAsync(Func<Task> action, bool clearSuccess = true)
    {
        try
        {
            _busy = true;
            _errorMessage = null;
            if (clearSuccess)
            {
                _successMessage = null;
            }

            await action();
        }
        catch (Exception exception)
        {
            _errorMessage = exception.Message;
            if (exception is PortalAdminApiException { StatusCode: 401 or 403 })
            {
                _session = await AdminClient.GetSessionAsync(_loadCancellation.Token);
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private void SetSuccess(string message)
    {
        _successMessage = message;
        _errorMessage = null;
    }

    private static Guid ParseRequiredGuid(string value, string label)
    {
        return Guid.TryParse(value, out var parsed)
            ? parsed
            : throw new InvalidOperationException($"{label} must be selected.");
    }

    private static int? ParseOptionalInt(string value)
    {
        var trimmed = value.Trim();
        if (trimmed.Length == 0)
        {
            return null;
        }

        return int.TryParse(trimmed, out var parsed)
            ? parsed
            : throw new InvalidOperationException("Digest interval must be a whole number of minutes.");
    }

    private static string[] ParseCsv(string value)
    {
        var parsed = value
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(entry => !string.IsNullOrWhiteSpace(entry))
            .Select(entry => entry.Trim())
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();

        return parsed.Length == 0
            ? throw new InvalidOperationException("At least one value is required.")
            : parsed;
    }

