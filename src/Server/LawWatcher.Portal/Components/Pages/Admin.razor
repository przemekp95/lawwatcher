@page "/admin"
@rendermode InteractiveServer
@implements IDisposable
@inject LawWatcherPortalAdminClient AdminClient
@inject IJSRuntime JS

<script type="module" src='@Assets["Components/Pages/Admin.razor.js"]'></script>

<PageTitle>Admin</PageTitle>

<section class="portal-shell">
    <div class="hero-panel">
        <p class="eyebrow">Operator admin</p>
        <h1>Secure admin writes across the internal control surface</h1>
        <p class="lede">
            This page signs into the internal API through the operator cookie flow and then performs antiforgery-protected admin commands for operators, monitoring profiles, subscriptions, webhooks and API clients.
        </p>
    </div>

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <section class="flash-banner flash-banner-success">
            <strong>Success:</strong> @_successMessage
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <section class="flash-banner flash-banner-error">
            <strong>Attention:</strong> @_errorMessage
        </section>
    }

    @if (_bootstrapStatus.RequiresOperatorBootstrap)
    {
        <section class="section-card">
            <div class="section-heading">
                <div>
                    <p class="section-kicker">Bootstrap</p>
                    <h2>First operator</h2>
                </div>
                <span class="status-pill">required</span>
            </div>
            <p class="admin-muted">
                This environment has no operator account yet. Use the bootstrap secret from the production env contract to create the first operator and start the cookie + CSRF operator flow.
            </p>
            <form class="admin-form-grid" @onsubmit="HandleBootstrapOperatorAsync" @onsubmit:preventDefault>
                <div class="field-stack admin-span-full">
                    <label for="bootstrap-secret">Bootstrap secret</label>
                    <input id="bootstrap-secret" class="portal-input" type="password" name="bootstrap-secret" autocomplete="off" @ref="_bootstrapSecretInput" @bind="_bootstrapOperator.Secret" />
                </div>
                <div class="field-stack">
                    <label for="bootstrap-operator-email">Email</label>
                    <input id="bootstrap-operator-email" class="portal-input" name="bootstrap-operator-email" autocomplete="username" @ref="_bootstrapOperatorEmailInput" @bind="_bootstrapOperator.Email" />
                </div>
                <div class="field-stack">
                    <label for="bootstrap-operator-display">Display name</label>
                    <input id="bootstrap-operator-display" class="portal-input" name="bootstrap-operator-display" autocomplete="name" @ref="_bootstrapOperatorDisplayInput" @bind="_bootstrapOperator.DisplayName" />
                </div>
                <div class="field-stack">
                    <label for="bootstrap-operator-password">Password</label>
                    <input id="bootstrap-operator-password" class="portal-input" type="password" name="bootstrap-operator-password" autocomplete="new-password" @ref="_bootstrapOperatorPasswordInput" @bind="_bootstrapOperator.Password" />
                </div>
                <div class="button-row">
                    <button type="submit" class="portal-button" disabled="@_busy">Create first operator</button>
                </div>
            </form>
        </section>
    }

    <section class="section-card">
        <div class="section-heading">
            <div>
                <p class="section-kicker">Session</p>
                <h2>Operator access</h2>
            </div>
            <span class="status-pill">@(_session.IsAuthenticated ? "signed in" : "anonymous")</span>
        </div>

        @if (!_session.IsAuthenticated)
        {
            <form class="admin-form-grid" @onsubmit="HandleLoginAsync" @onsubmit:preventDefault>
                <div class="field-stack">
                    <label for="operator-email">Email</label>
                    <input id="operator-email" class="portal-input" name="operator-email" autocomplete="username" @ref="_loginEmailInput" @bind="_login.Email" />
                </div>
                <div class="field-stack">
                    <label for="operator-password">Password</label>
                    <input id="operator-password" class="portal-input" type="password" name="operator-password" autocomplete="current-password" @ref="_loginPasswordInput" @bind="_login.Password" />
                </div>
                <div class="button-row">
                    <button type="submit" class="portal-button" disabled="@_busy">Sign in</button>
                </div>
            </form>
        }
        else
        {
            <div class="auth-summary">
                <div>
                    <strong>@_session.DisplayName</strong>
                    <p>@_session.Email</p>
                </div>
                <div class="capability-strip">
                    @foreach (var permission in _session.Permissions)
                    {
                        <span class="status-pill">@permission</span>
                    }
                </div>
            </div>
            <div class="button-row">
                <button type="button" class="portal-button portal-button-secondary" @onclick="RefreshAsync" disabled="@_busy">Refresh</button>
                <button type="button" class="portal-button portal-button-danger" @onclick="HandleLogoutAsync" disabled="@_busy">Sign out</button>
            </div>
        }
    </section>

    @if (_session.IsAuthenticated && _bootstrapStatus.CanBootstrapApiClient)
    {
        <section class="section-card">
            <div class="section-heading">
                <div>
                    <p class="section-kicker">Bootstrap</p>
                    <h2>Initial API client</h2>
                </div>
                <span class="status-pill">optional</span>
            </div>
            <p class="admin-muted">
                Create the first bearer client for the integration platform. The raw token is shown once, so rotate it into your secret store immediately.
            </p>
            <form class="admin-form-grid" @onsubmit="HandleBootstrapApiClientAsync" @onsubmit:preventDefault>
                <div class="field-stack">
                    <label for="bootstrap-api-client-name">Name</label>
                    <input id="bootstrap-api-client-name" class="portal-input" @bind="_bootstrapApiClient.Name" />
                </div>
                <div class="field-stack">
                    <label for="bootstrap-api-client-identifier">Client identifier</label>
                    <input id="bootstrap-api-client-identifier" class="portal-input" @bind="_bootstrapApiClient.ClientIdentifier" />
                </div>
                <div class="field-stack admin-span-full">
                    <label for="bootstrap-api-client-scopes">Scopes</label>
                    <input id="bootstrap-api-client-scopes" class="portal-input" @bind="_bootstrapApiClient.ScopesCsv" />
                </div>
                <div class="button-row">
                    <button type="submit" class="portal-button" disabled="@_busy">Create initial API client</button>
                </div>
            </form>

            @if (!string.IsNullOrWhiteSpace(_bootstrappedApiClientToken))
            {
                <div class="admin-top-gap">
                    <p class="section-kicker">One-time token</p>
                    <code>@_bootstrappedApiClientToken</code>
                </div>
            }
        </section>
    }

    @if (_session.IsAuthenticated)
    {
        <section class="admin-grid two-up">
            <article class="section-card">
                <div class="section-heading">
                    <div>
                        <p class="section-kicker">Operators</p>
                        <h2>Create operator</h2>
                    </div>
                    <span class="status-pill">@_operators.Count operator(s)</span>
                </div>

                <form class="admin-form-grid" @onsubmit="HandleCreateOperatorAsync" @onsubmit:preventDefault>
                    <div class="field-stack">
                        <label for="operator-create-email">Email</label>
                        <input id="operator-create-email" class="portal-input" @bind="_operatorCreate.Email" />
                    </div>
                    <div class="field-stack">
                        <label for="operator-create-display">Display name</label>
                        <input id="operator-create-display" class="portal-input" @bind="_operatorCreate.DisplayName" />
                    </div>
                    <div class="field-stack">
                        <label for="operator-create-password">Password</label>
                        <input id="operator-create-password" class="portal-input" type="password" @bind="_operatorCreate.Password" />
                    </div>
                    <div class="field-stack admin-span-full">
                        <label for="operator-create-permissions">Permissions</label>
                        <input id="operator-create-permissions" class="portal-input" @bind="_operatorCreate.PermissionsCsv" placeholder="operators:write, profiles:write" />
                    </div>
                    <div class="button-row">
                        <button type="submit" class="portal-button" disabled="@_busy">Create operator</button>
                    </div>
                </form>

                <div class="admin-list">
                    @foreach (var operatorAccount in _operators)
                    {
                        <article class="admin-item-card">
                            <div class="admin-item-heading">
                                <strong>@operatorAccount.DisplayName</strong>
                                <span class="status-pill">@(operatorAccount.IsActive ? "active" : "inactive")</span>
                            </div>
                            <p>@operatorAccount.Email</p>
                            <p class="admin-muted">@string.Join(", ", operatorAccount.Permissions)</p>
                            <div class="button-row admin-top-gap">
                                <button
                                    type="button"
                                    class="portal-button portal-button-danger"
                                    @onclick="() => HandleDeactivateOperatorAsync(operatorAccount.Id)"
                                    disabled="@(_busy || !operatorAccount.IsActive || operatorAccount.Id == _session.OperatorId)">
                                    Deactivate
                                </button>
                            </div>
                        </article>
                    }
                </div>
            </article>

            <article class="section-card">
                <div class="section-heading">
                    <div>
                        <p class="section-kicker">Operators</p>
                        <h2>Update or reset operator</h2>
                    </div>
                </div>

                <form class="admin-form-grid" @onsubmit="HandleUpdateOperatorAsync" @onsubmit:preventDefault>
                    <div class="field-stack">
                        <label for="operator-update-target">Operator</label>
                        <select id="operator-update-target" class="portal-select" @bind="_operatorUpdate.OperatorId">
                            <option value="">Choose operator</option>
                            @foreach (var operatorAccount in _operators)
                            {
                                <option value="@operatorAccount.Id">@operatorAccount.Email</option>
                            }
                        </select>
                    </div>
                    <div class="field-stack">
                        <label for="operator-update-display">Display name</label>
                        <input id="operator-update-display" class="portal-input" @bind="_operatorUpdate.DisplayName" />
                    </div>
                    <div class="field-stack admin-span-full">
                        <label for="operator-update-permissions">Permissions</label>
                        <input id="operator-update-permissions" class="portal-input" @bind="_operatorUpdate.PermissionsCsv" placeholder="operators:write, profiles:write" />
                    </div>
                    <div class="button-row">
                        <button type="submit" class="portal-button portal-button-secondary" disabled="@_busy">Update operator</button>
                    </div>
                </form>

                <form class="admin-form-grid admin-top-gap" @onsubmit="HandleResetOperatorPasswordAsync" @onsubmit:preventDefault>
                    <div class="field-stack">
                        <label for="operator-reset-target">Operator</label>
                        <select id="operator-reset-target" class="portal-select" @bind="_operatorReset.OperatorId">
                            <option value="">Choose operator</option>
                            @foreach (var operatorAccount in _operators)
                            {
                                <option value="@operatorAccount.Id">@operatorAccount.Email</option>
                            }
                        </select>
                    </div>
                    <div class="field-stack">
                        <label for="operator-reset-password">New password</label>
                        <input id="operator-reset-password" class="portal-input" type="password" @bind="_operatorReset.NewPassword" />
                    </div>
                    <div class="button-row">
                        <button type="submit" class="portal-button portal-button-secondary" disabled="@_busy">Reset password</button>
                    </div>
                </form>
            </article>
        </section>

        <section class="admin-grid two-up">
            <article class="section-card">
                <div class="section-heading">
                    <div>
                        <p class="section-kicker">Monitoring</p>
                        <h2>Create profile</h2>
                    </div>
                    <span class="status-pill">@_profiles.Count profile(s)</span>
                </div>

                <form class="admin-form-grid" @onsubmit="HandleCreateProfileAsync" @onsubmit:preventDefault>
                    <div class="field-stack">
                        <label for="profile-name">Name</label>
                        <input id="profile-name" class="portal-input" @bind="_profileCreate.Name" />
                    </div>
                    <div class="field-stack">
                        <label for="profile-policy">Alert policy</label>
                        <select id="profile-policy" class="portal-select" @bind="_profileCreate.AlertPolicy">
                            <option value="immediate">immediate</option>
                            <option value="digest">digest</option>
                        </select>
                    </div>
                    <div class="field-stack">
                        <label for="profile-digest">Digest interval minutes</label>
                        <input id="profile-digest" class="portal-input" @bind="_profileCreate.DigestIntervalMinutes" />
                    </div>
                    <div class="field-stack admin-span-full">
                        <label for="profile-keywords">Keywords</label>
                        <input id="profile-keywords" class="portal-input" @bind="_profileCreate.KeywordsCsv" placeholder="vat, cit, akcyza" />
                    </div>
                    <div class="button-row">
                        <button type="submit" class="portal-button" disabled="@_busy">Create profile</button>
                    </div>
                </form>

                <div class="admin-list">
                    @foreach (var profile in _profiles)
                    {
                        <article class="admin-item-card">
                            <div class="admin-item-heading">
                                <strong>@profile.Name</strong>
                                <span class="status-pill">@profile.AlertPolicy</span>
                            </div>
                            <p>@string.Join(", ", profile.Keywords)</p>
                            <p class="admin-muted">@profile.RuleCount rule(s)</p>
                            <div class="button-row admin-top-gap">
                                <button
                                    type="button"
                                    class="portal-button portal-button-danger"
                                    @onclick="() => HandleDeactivateProfileAsync(profile.Id)"
                                    disabled="@_busy">
                                    Deactivate
                                </button>
                            </div>
                        </article>
                    }
                </div>
            </article>

            <article class="section-card">
                <div class="section-heading">
                    <div>
                        <p class="section-kicker">Monitoring</p>
                        <h2>Update profile</h2>
                    </div>
                </div>

                <form class="admin-form-grid" @onsubmit="HandleAddProfileRuleAsync" @onsubmit:preventDefault>
                    <div class="field-stack">
                        <label for="profile-rule-target">Profile</label>
                        <select id="profile-rule-target" class="portal-select" @bind="_profileRule.ProfileId">
                            <option value="">Choose profile</option>
                            @foreach (var profile in _profiles)
                            {
                                <option value="@profile.Id">@profile.Name</option>
                            }
                        </select>
                    </div>
                    <div class="field-stack">
                        <label for="profile-rule-keyword">Keyword</label>
                        <input id="profile-rule-keyword" class="portal-input" @bind="_profileRule.Keyword" />
                    </div>
                    <div class="button-row">
                        <button type="submit" class="portal-button" disabled="@_busy">Add rule</button>
                    </div>
                </form>

                <form class="admin-form-grid admin-top-gap" @onsubmit="HandleChangeProfilePolicyAsync" @onsubmit:preventDefault>
                    <div class="field-stack">
                        <label for="profile-policy-target">Profile</label>
                        <select id="profile-policy-target" class="portal-select" @bind="_profilePolicy.ProfileId">
                            <option value="">Choose profile</option>
                            @foreach (var profile in _profiles)
                            {
                                <option value="@profile.Id">@profile.Name</option>
                            }
                        </select>
                    </div>
                    <div class="field-stack">
                        <label for="profile-policy-value">Alert policy</label>
                        <select id="profile-policy-value" class="portal-select" @bind="_profilePolicy.AlertPolicy">
                            <option value="immediate">immediate</option>
                            <option value="digest">digest</option>
                        </select>
                    </div>
                    <div class="field-stack">
                        <label for="profile-policy-digest">Digest interval minutes</label>
                        <input id="profile-policy-digest" class="portal-input" @bind="_profilePolicy.DigestIntervalMinutes" />
                    </div>
                    <div class="button-row">
                        <button type="submit" class="portal-button portal-button-secondary" disabled="@_busy">Change policy</button>
                    </div>
                </form>
            </article>
        </section>

        <section class="admin-grid two-up">
            <article class="section-card">
                <div class="section-heading">
                    <div>
                        <p class="section-kicker">Subscriptions</p>
                        <h2>Create subscription</h2>
                    </div>
                    <span class="status-pill">@_subscriptions.Count subscription(s)</span>
                </div>

                <form class="admin-form-grid" @onsubmit="HandleCreateSubscriptionAsync" @onsubmit:preventDefault>
                    <div class="field-stack">
                        <label for="subscription-profile">Profile</label>
                        <select id="subscription-profile" class="portal-select" @bind="_subscriptionCreate.ProfileId">
                            <option value="">Choose profile</option>
                            @foreach (var profile in _profiles)
                            {
                                <option value="@profile.Id">@profile.Name</option>
                            }
                        </select>
                    </div>
                    <div class="field-stack">
                        <label for="subscription-subscriber">Subscriber</label>
                        <input id="subscription-subscriber" class="portal-input" @bind="_subscriptionCreate.Subscriber" />
                    </div>
                    <div class="field-stack">
                        <label for="subscription-channel">Channel</label>
                        <select id="subscription-channel" class="portal-select" @bind="_subscriptionCreate.Channel">
                            <option value="email">email</option>
                            <option value="webhook">webhook</option>
                        </select>
                    </div>
                    <div class="field-stack">
                        <label for="subscription-policy">Alert policy</label>
                        <select id="subscription-policy" class="portal-select" @bind="_subscriptionCreate.AlertPolicy">
                            <option value="immediate">immediate</option>
                            <option value="digest">digest</option>
                        </select>
                    </div>
                    <div class="field-stack">
                        <label for="subscription-digest">Digest interval minutes</label>
                        <input id="subscription-digest" class="portal-input" @bind="_subscriptionCreate.DigestIntervalMinutes" />
                    </div>
                    <div class="button-row">
                        <button type="submit" class="portal-button" disabled="@_busy">Create subscription</button>
                    </div>
                </form>

                <div class="admin-list">
                    @foreach (var subscription in _subscriptions)
                    {
                        <article class="admin-item-card">
                            <div class="admin-item-heading">
                                <strong>@subscription.ProfileName</strong>
                                <span class="status-pill">@subscription.Channel</span>
                            </div>
                            <p>@subscription.Subscriber</p>
                            <p class="admin-muted">@subscription.AlertPolicy @(subscription.DigestIntervalMinutes is null ? string.Empty : $"- {subscription.DigestIntervalMinutes} min")</p>
                            <div class="button-row admin-top-gap">
                                <button
                                    type="button"
                                    class="portal-button portal-button-danger"
                                    @onclick="() => HandleDeactivateSubscriptionAsync(subscription.Id)"
                                    disabled="@_busy">
                                    Deactivate
                                </button>
                            </div>
                        </article>
                    }
                </div>
            </article>

            <article class="section-card">
                <div class="section-heading">
                    <div>
                        <p class="section-kicker">Subscriptions</p>
                        <h2>Update subscription policy</h2>
                    </div>
                </div>

                <form class="admin-form-grid" @onsubmit="HandleChangeSubscriptionPolicyAsync" @onsubmit:preventDefault>
                    <div class="field-stack">
                        <label for="subscription-target">Subscription</label>
                        <select id="subscription-target" class="portal-select" @bind="_subscriptionPolicy.SubscriptionId">
                            <option value="">Choose subscription</option>
                            @foreach (var subscription in _subscriptions)
                            {
                                <option value="@subscription.Id">@subscription.ProfileName - @subscription.Subscriber</option>
                            }
                        </select>
                    </div>
                    <div class="field-stack">
                        <label for="subscription-policy-value">Alert policy</label>
                        <select id="subscription-policy-value" class="portal-select" @bind="_subscriptionPolicy.AlertPolicy">
                            <option value="immediate">immediate</option>
                            <option value="digest">digest</option>
                        </select>
                    </div>
                    <div class="field-stack">
                        <label for="subscription-policy-digest">Digest interval minutes</label>
                        <input id="subscription-policy-digest" class="portal-input" @bind="_subscriptionPolicy.DigestIntervalMinutes" />
                    </div>
                    <div class="button-row">
                        <button type="submit" class="portal-button portal-button-secondary" disabled="@_busy">Change subscription policy</button>
                    </div>
                </form>
            </article>
        </section>

        <section class="admin-grid two-up">
            <article class="section-card">
                <div class="section-heading">
                    <div>
                        <p class="section-kicker">Integrations</p>
                        <h2>Webhooks</h2>
                    </div>
                    <span class="status-pill">@_webhooks.Count webhook(s)</span>
                </div>

                <form class="admin-form-grid" @onsubmit="HandleCreateWebhookAsync" @onsubmit:preventDefault>
                    <div class="field-stack">
                        <label for="webhook-name">Name</label>
                        <input id="webhook-name" class="portal-input" @bind="_webhookCreate.Name" />
                    </div>
                    <div class="field-stack">
                        <label for="webhook-url">Callback URL</label>
                        <input id="webhook-url" class="portal-input" @bind="_webhookCreate.CallbackUrl" />
                    </div>
                    <div class="field-stack admin-span-full">
                        <label for="webhook-events">Event types</label>
                        <input id="webhook-events" class="portal-input" @bind="_webhookCreate.EventTypesCsv" placeholder="alert.created" />
                    </div>
                    <div class="button-row">
                        <button type="submit" class="portal-button" disabled="@_busy">Create webhook</button>
                    </div>
                </form>

                <div class="admin-list">
                    @foreach (var webhook in _webhooks)
                    {
                        <article class="admin-item-card">
                            <div class="admin-item-heading">
                                <strong>@webhook.Name</strong>
                                <span class="status-pill">@(webhook.IsActive ? "active" : "inactive")</span>
                            </div>
                            <p>@webhook.CallbackUrl</p>
                            <p class="admin-muted">@string.Join(", ", webhook.EventTypes)</p>
                            <div class="button-row admin-top-gap">
                                <button
                                    type="button"
                                    class="portal-button portal-button-danger"
                                    @onclick="() => HandleDeactivateWebhookAsync(webhook.Id)"
                                    disabled="@(_busy || !webhook.IsActive)">
                                    Deactivate
                                </button>
                            </div>
                        </article>
                    }
                </div>
            </article>

            <article class="section-card">
                <div class="section-heading">
                    <div>
                        <p class="section-kicker">Integrations</p>
                        <h2>API clients</h2>
                    </div>
                    <span class="status-pill">@_apiClients.Count client(s)</span>
                </div>

                <form class="admin-form-grid" @onsubmit="HandleCreateApiClientAsync" @onsubmit:preventDefault>
                    <div class="field-stack">
                        <label for="api-client-name">Name</label>
                        <input id="api-client-name" class="portal-input" @bind="_apiClientCreate.Name" />
                    </div>
                    <div class="field-stack">
                        <label for="api-client-identifier">Client identifier</label>
                        <input id="api-client-identifier" class="portal-input" @bind="_apiClientCreate.ClientIdentifier" />
                    </div>
                    <div class="field-stack">
                        <label for="api-client-token">Token</label>
                        <input id="api-client-token" class="portal-input" @bind="_apiClientCreate.Token" />
                    </div>
                    <div class="field-stack admin-span-full">
                        <label for="api-client-scopes">Scopes</label>
                        <input id="api-client-scopes" class="portal-input" @bind="_apiClientCreate.ScopesCsv" placeholder="profiles:write, subscriptions:write" />
                    </div>
                    <div class="button-row">
                        <button type="submit" class="portal-button" disabled="@_busy">Create API client</button>
                    </div>
                </form>

                <div class="admin-list">
                    @foreach (var apiClient in _apiClients)
                    {
                        <article class="admin-item-card">
                            <div class="admin-item-heading">
                                <strong>@apiClient.Name</strong>
                                <span class="status-pill">@(apiClient.IsActive ? "active" : "inactive")</span>
                            </div>
                            <p>@apiClient.ClientIdentifier</p>
                            <p class="admin-muted">Fingerprint: @apiClient.TokenFingerprint</p>
                            <p class="admin-muted">@string.Join(", ", apiClient.Scopes)</p>
                            <div class="button-row admin-top-gap">
                                <button
                                    type="button"
                                    class="portal-button portal-button-danger"
                                    @onclick="() => HandleDeactivateApiClientAsync(apiClient.Id)"
                                    disabled="@(_busy || !apiClient.IsActive)">
                                    Deactivate
                                </button>
                            </div>
                        </article>
                    }
                </div>
            </article>
        </section>

        <section class="admin-grid two-up">
            <article class="section-card">
                <div class="section-heading">
                    <div>
                        <p class="section-kicker">Integrations</p>
                        <h2>Update webhook</h2>
                    </div>
                </div>

                <form class="admin-form-grid" @onsubmit="HandleUpdateWebhookAsync" @onsubmit:preventDefault>
                    <div class="field-stack">
                        <label for="webhook-update-target">Webhook</label>
                        <select id="webhook-update-target" class="portal-select" @bind="_webhookUpdate.WebhookId">
                            <option value="">Choose webhook</option>
                            @foreach (var webhook in _webhooks)
                            {
                                <option value="@webhook.Id">@webhook.Name</option>
                            }
                        </select>
                    </div>
                    <div class="field-stack">
                        <label for="webhook-update-name">Name</label>
                        <input id="webhook-update-name" class="portal-input" @bind="_webhookUpdate.Name" />
                    </div>
                    <div class="field-stack admin-span-full">
                        <label for="webhook-update-url">Callback URL</label>
                        <input id="webhook-update-url" class="portal-input" @bind="_webhookUpdate.CallbackUrl" />
                    </div>
                    <div class="field-stack admin-span-full">
                        <label for="webhook-update-events">Event types</label>
                        <input id="webhook-update-events" class="portal-input" @bind="_webhookUpdate.EventTypesCsv" placeholder="alert.created, bill.imported" />
                    </div>
                    <div class="button-row">
                        <button type="submit" class="portal-button portal-button-secondary" disabled="@_busy">Update webhook</button>
                    </div>
                </form>
            </article>

            <article class="section-card">
                <div class="section-heading">
                    <div>
                        <p class="section-kicker">Integrations</p>
                        <h2>Update API client</h2>
                    </div>
                </div>

                <form class="admin-form-grid" @onsubmit="HandleUpdateApiClientAsync" @onsubmit:preventDefault>
                    <div class="field-stack">
                        <label for="api-client-update-target">API client</label>
                        <select id="api-client-update-target" class="portal-select" @bind="_apiClientUpdate.ApiClientId">
                            <option value="">Choose API client</option>
                            @foreach (var apiClient in _apiClients)
                            {
                                <option value="@apiClient.Id">@apiClient.ClientIdentifier</option>
                            }
                        </select>
                    </div>
                    <div class="field-stack">
                        <label for="api-client-update-name">Name</label>
                        <input id="api-client-update-name" class="portal-input" @bind="_apiClientUpdate.Name" />
                    </div>
                    <div class="field-stack admin-span-full">
                        <label for="api-client-update-scopes">Scopes</label>
                        <input id="api-client-update-scopes" class="portal-input" @bind="_apiClientUpdate.ScopesCsv" placeholder="profiles:write, webhooks:write" />
                    </div>
                    <div class="field-stack admin-span-full">
                        <label for="api-client-update-token">New token</label>
                        <input id="api-client-update-token" class="portal-input" @bind="_apiClientUpdate.Token" placeholder="leave blank to keep current token" />
                    </div>
                    <div class="button-row">
                        <button type="submit" class="portal-button portal-button-secondary" disabled="@_busy">Update API client</button>
                    </div>
                </form>
            </article>
        </section>
    }
</section>

@code {
    private readonly CancellationTokenSource _loadCancellation = new();

