    private OperatorSessionResponse _session = new(false, null, null, null, Array.Empty<string>(), string.Empty);
    private List<OperatorAccountResponse> _operators = [];
    private List<MonitoringProfileResponse> _profiles = [];
    private List<ProfileSubscriptionResponse> _subscriptions = [];
    private List<WebhookRegistrationResponse> _webhooks = [];
    private List<ApiClientResponse> _apiClients = [];

    private BootstrapOperatorInput _bootstrapOperator = new();
    private BootstrapApiClientInput _bootstrapApiClient = new();
    private LoginInput _login = new();
    private OperatorCreateInput _operatorCreate = new();
    private OperatorUpdateInput _operatorUpdate = new();
    private OperatorResetInput _operatorReset = new();
    private ProfileCreateInput _profileCreate = new();
    private ProfileRuleInput _profileRule = new();
    private ProfilePolicyInput _profilePolicy = new();
    private SubscriptionCreateInput _subscriptionCreate = new();
    private SubscriptionPolicyInput _subscriptionPolicy = new();
    private WebhookCreateInput _webhookCreate = new();
    private WebhookUpdateInput _webhookUpdate = new();
    private ApiClientCreateInput _apiClientCreate = new();
    private ApiClientUpdateInput _apiClientUpdate = new();

    private string? _bootstrappedApiClientToken;
    private string? _successMessage;
    private string? _errorMessage;
    private bool _busy;
    private ElementReference _bootstrapSecretInput;
    private ElementReference _bootstrapOperatorEmailInput;
    private ElementReference _bootstrapOperatorDisplayInput;
    private ElementReference _bootstrapOperatorPasswordInput;
    private ElementReference _loginEmailInput;
    private ElementReference _loginPasswordInput;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    public void Dispose()
    {
        _loadCancellation.Cancel();
        _loadCancellation.Dispose();
    }

    private async Task SynchronizeBootstrapOperatorInputsAsync()
    {
        _bootstrapOperator.Secret = await ReadDomInputValueAsync(_bootstrapSecretInput, _bootstrapOperator.Secret);
        _bootstrapOperator.Email = await ReadDomInputValueAsync(_bootstrapOperatorEmailInput, _bootstrapOperator.Email);
        _bootstrapOperator.DisplayName = await ReadDomInputValueAsync(_bootstrapOperatorDisplayInput, _bootstrapOperator.DisplayName);
        _bootstrapOperator.Password = await ReadDomInputValueAsync(_bootstrapOperatorPasswordInput, _bootstrapOperator.Password);
    }

    private async Task SynchronizeLoginInputsAsync()
    {
        _login.Email = await ReadDomInputValueAsync(_loginEmailInput, _login.Email);
        _login.Password = await ReadDomInputValueAsync(_loginPasswordInput, _login.Password);
    }

    // Password managers and browser autofill can update the DOM without raising
    // the Blazor change events that keep these form models in sync.
    private async Task<string> ReadDomInputValueAsync(ElementReference input, string fallback)
    {
        try
        {
            var currentValue = await JS.InvokeAsync<string?>("lawWatcherPortalAdmin.readInputValue", input);
            return currentValue ?? fallback;
        }
        catch (JSDisconnectedException)
        {
            return fallback;
        }
        catch (JSException)
        {
            return fallback;
        }
        catch (InvalidOperationException)
        {
            return fallback;
        }
    }

    private async Task RefreshAsync()
    {
        await ExecuteBusyActionAsync(async () =>
        {
            _bootstrapStatus = await AdminClient.GetBootstrapStatusAsync(_loadCancellation.Token);
            _session = await AdminClient.GetSessionAsync(_loadCancellation.Token);
            if (_session.IsAuthenticated)
            {
                await LoadDataAsync();
            }
            else
            {
                _operators = [];
                _profiles = [];
                _subscriptions = [];
                _webhooks = [];
                _apiClients = [];
            }
        }, clearSuccess: false);
    }

    private async Task HandleBootstrapOperatorAsync()
    {
        await ExecuteBusyActionAsync(async () =>
        {
            await SynchronizeBootstrapOperatorInputsAsync();
            _session = await AdminClient.BootstrapFirstOperatorAsync(
                new BootstrapOperatorRequest(
                    _bootstrapOperator.Email,
                    _bootstrapOperator.DisplayName,
                    _bootstrapOperator.Password),
                _bootstrapOperator.Secret,
                _loadCancellation.Token);

            _bootstrapOperator = new BootstrapOperatorInput();
            _bootstrappedApiClientToken = null;
            await LoadDataAsync();
            _bootstrapStatus = await AdminClient.GetBootstrapStatusAsync(_loadCancellation.Token);
            SetSuccess("First operator bootstrapped and signed in.");
        });
    }

    private async Task HandleBootstrapApiClientAsync()
    {
        await ExecuteBusyActionAsync(async () =>
        {
            var response = await AdminClient.BootstrapInitialApiClientAsync(
                new BootstrapApiClientRequest(
                    _bootstrapApiClient.Name,
                    _bootstrapApiClient.ClientIdentifier,
                    ParseCsv(_bootstrapApiClient.ScopesCsv)),
                _loadCancellation.Token);

            _bootstrapApiClient = new BootstrapApiClientInput();
            _bootstrappedApiClientToken = response.Token;
            await LoadDataAsync();
            _bootstrapStatus = await AdminClient.GetBootstrapStatusAsync(_loadCancellation.Token);
            SetSuccess("Initial API client created.");
        });
    }

    private async Task HandleLoginAsync()
    {
        await ExecuteBusyActionAsync(async () =>
        {
            await SynchronizeLoginInputsAsync();
            _session = await AdminClient.LoginAsync(_login.Email, _login.Password, _loadCancellation.Token);
            _login = new LoginInput();
            await LoadDataAsync();
            SetSuccess("Operator session established.");
        });
    }

    private async Task HandleLogoutAsync()
    {
        await ExecuteBusyActionAsync(async () =>
        {
            _session = await AdminClient.LogoutAsync(_loadCancellation.Token);
            _operators = [];
            _profiles = [];
            _subscriptions = [];
            _webhooks = [];
            _apiClients = [];
            _bootstrappedApiClientToken = null;
            _bootstrapStatus = await AdminClient.GetBootstrapStatusAsync(_loadCancellation.Token);
            SetSuccess("Operator session closed.");
        });
    }

