{
  "LawWatcher": {
    "Runtime": {
      "Profile": "full-host",
      "Capabilities": {
        "Ai": true,
        "Ocr": false,
        "Replay": true,
        "SemanticSearch": false,
        "HybridSearch": false
      }
    },
    "Storage": {
      "Provider": "files",
      "StateRoot": "../../../artifacts/state",
      "SqlServerConnectionStringName": "LawWatcherSqlServer"
    },
    "WorkerLite": {
      "MaxConcurrency": 2,
      "EnabledPipelines": [ "notifications" ]
    },
    "Webhooks": {
      "Backend": "InMemory",
      "SigningSecret": "local-dev-webhook-secret",
      "TimeoutSeconds": 10
    }
  },
  "ConnectionStrings": {
    "LawWatcherSqlServer": "Server=127.0.0.1,1433;Database=LawWatcher;User Id=sa;Password=ChangeMe!123456;TrustServerCertificate=true;Encrypt=false;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
